##RenderMan RIB-Structure 1.0
version 3.03
#
# skylight.rib
#
# Example RIB file to show use of indirect lighting global illumination to
# accelerate hemispherical lighting simulations in BMRT.
#

Format 480 360 1
#PixelSamples 3 3
Option "searchpath" "shader" [".:../shaders:&"]
Projection "perspective"  "fov" [20]

##CameraOrientation 2 20 5 0 0 1.5 -0.0170699 -0.170699 0.985175
ConcatTransform [0.995037 -0.0170699 -0.0980286 0 -0.0995037 -0.170699 -0.980286 0 1.86265e-09 0.985175 -0.17155 0 0 0 0 1]
Translate -2 -20 -5 

LightSource "shadowdistant" 3 "from" [ 1 1 1] "to" [ 0 0 0] "intensity" 1.2 "string shadowname" ["raytrace"]


FrameBegin 1
Display "skylight.direct.tif" "file" "rgba"

WorldBegin
ReverseOrientation
AttributeBegin
  Surface "fakesky"
  Sphere 22 -22 22 360
AttributeEnd

